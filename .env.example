# AI Configuration
# If left empty, the system will run in "Mock Mode" (Backend works, but AI features return generic placeholders)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email OTP (Gmail SMTP)
# Use your Gmail address and a Google App Password (NOT your regular Gmail password)
# How to get an App Password:
#   1. Enable 2FA: https://myaccount.google.com/security
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Select "Mail" → copy the 16-character password
# Leave empty to use MOCK mode — code '123456' verifies any email locally
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# App Configuration
# Defaults are safe for local development, but you can override them here
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///./lifeflow.db
LLM_PROVIDER=gemini

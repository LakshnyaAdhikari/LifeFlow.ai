# AI Configuration
# If left empty, the system will run in "Mock Mode" (Backend works, but AI features return generic placeholders)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email OTP (Resend)
# Get your free API key at https://resend.com
# Leave empty to run in mock mode — use code '123456' to verify any email locally
RESEND_API_KEY=
# The "from" address — must be a verified domain in your Resend account.
# For testing, the default onboarding@resend.dev works without domain verification.
RESEND_FROM_EMAIL=onboarding@resend.dev

# App Configuration
# Defaults are safe for local development, but you can override them here
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///./lifeflow.db
LLM_PROVIDER=gemini
